#include <iostream>
using namespace std;

struct Node {
    int data;
    Node *next, *prev;
};

void deleteValue(Node*& head, int val) {
    if (!head) return;

    Node* curr = head;

    do {
        if (curr->data == val) {

            if (curr->next == curr) {
                delete curr;
                head = NULL;
                return;
            }

            curr->prev->next = curr->next;
            curr->next->prev = curr->prev;

            if (curr == head)
                head = curr->next;

            delete curr;
            return;
        }
        curr = curr->next;
    } while (curr != head);
}

