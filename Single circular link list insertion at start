#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

void insertStart(Node*& head, int val) {
    Node* temp = new Node{val, NULL};

    if (!head) {
        head = temp;
        temp->next = head;
        return;
    }

    Node* last = head;
    while (last->next != head)
        last = last->next;

    temp->next = head;
    last->next = temp;
    head = temp;
}

void display(Node* head) {
    if (!head) return;
    Node* p = head;
    do {
        cout << p->data << " ";
        p = p->next;
    } while (p != head);
}

int main() {
    Node* head = NULL;
    insertStart(head, 10);
    insertStart(head, 20);
    display(head);
}
