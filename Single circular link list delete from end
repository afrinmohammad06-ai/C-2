#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

void deleteEnd(Node*& head) {
    if (!head) return;

    if (head->next == head) {
        delete head;
        head = NULL;
        return;
    }

    Node* prev = NULL;
    Node* curr = head;

    while (curr->next != head) {
        prev = curr;
        curr = curr->next;
    }

    prev->next = head;
    delete curr;
}

