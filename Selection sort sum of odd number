#include <iostream>
using namespace std;

int sumOddElements(int arr[], int n) {
    int sum = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] % 2 != 0) {
            sum += arr[i];
        }
    }
    return sum;
}

int main() {
    int ar[] = {58, 23, 16, 25, 19};
    int n = sizeof(ar) / sizeof(ar[0]);
    int oddSum = sumOddElements(ar, n);
    cout << "Original array: ";
    for (int i = 0; i < n; i++) {
        cout << ar[i] << " ";
    }
    cout << endl;
    cout << "Sum of odd elements: " << oddSum << endl;
    return 0;
}
