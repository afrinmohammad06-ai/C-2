#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

void insertPos(Node*& head, int val, int pos) {
    Node* temp = new Node{val, NULL};

    if (pos == 1) {
        if (!head) {
            head = temp;
            temp->next = head;
            return;
        }

        Node* last = head;
        while (last->next != head)
            last = last->next;

        temp->next = head;
        last->next = temp;
        head = temp;
        return;
    }

    Node* p = head;
    for (int i = 1; i < pos - 1 && p->next != head; i++)
        p = p->next;

    temp->next = p->next;
    p->next = temp;
}

int main() {
    Node* head = NULL;
    insertPos(head, 10, 1);
    insertPos(head, 20, 2);
    insertPos(head, 15, 2);
}
