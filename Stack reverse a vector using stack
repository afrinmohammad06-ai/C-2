#include <iostream>
#include <vector>
#include <stack>
using namespace std;

int main() {
    vector<int> v = {1, 2, 3, 4, 5};
    stack<int> s;

    // Push into stack
    for (int i = 0; i < v.size(); i++) {
        s.push(v[i]);
    }

    // Pop back to vector
    for (int i = 0; i < v.size(); i++) {
        v[i] = s.top();
        s.pop();
    }

    cout << "Reversed vector: ";
    for (int x : v)
        cout << x << " ";

    return 0;
}
