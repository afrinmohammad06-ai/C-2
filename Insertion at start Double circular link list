#include <iostream>
using namespace std;

struct Node {
    int data;
    Node *next, *prev;
};

void insertStart(Node*& head, int val) {
    Node* temp = new Node{val, NULL, NULL};

    if (!head) {
        head = temp;
        head->next = head->prev = head;
        return;
    }

    Node* last = head->prev;

    temp->next = head;
    temp->prev = last;
    last->next = temp;
    head->prev = temp;
    head = temp;
}

void display(Node* head) {
    if (!head) return;
    Node* p = head;
    do {
        cout << p->data << " ";
        p = p->next;
    } while (p != head);
}

int main() {
    Node* head = NULL;
    insertStart(head, 10);
    insertStart(head, 20);
    display(head);
}
